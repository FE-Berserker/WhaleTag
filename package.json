    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.4",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@excalidraw/excalidraw": "^0.18.1",
    "@mui/icons-material": "9.1.0",
