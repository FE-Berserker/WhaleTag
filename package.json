{
  "name": "whaletag",
  "productName": "WhaleTag",
  "version": "0.2.0",
  "description": "WhaleTag - a local-first, offline file manager and tagging tool (Electron + React + TypeScript)",
  "keywords": [
    "electron",
    "react",
    "typescript",
    "file-manager",
    "tagging"
  ],
  "license": "MIT",
  "author": {
    "name": "WhaleTag"
  },
  "main": "./release/app/dist/main/main.js",
  "scripts": {
    "dev": "npm run build:main:dev && npm run build:extensions && concurrently -k \"npm run watch:main\" \"npm run dev:renderer\" \"wait-on tcp:4002 && cross-env NODE_ENV=development electronmon .\"",
    "build:main:dev": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.main.dev.ts",
    "watch:main": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack --watch --config ./.erb/configs/webpack.config.main.dev.ts",
    "dev:renderer": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack serve --config ./.erb/configs/webpack.config.renderer.dev.ts",
    "build": "npm run build:main && npm run build:extensions && npm run build:renderer",
    "build:main": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.main.prod.ts",
    "build:extensions": "node scripts/build-extensions.js",
    "build:ai-component": "node scripts/build-ai-component.js",
    "watch:extensions": "node scripts/build-extensions.js --watch",
    "build:renderer": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.renderer.prod.ts",
    "start": "cross-env NODE_ENV=production electron ./release/app/dist/main/main.js",
    "package": "npm run build && electron-builder --config resources/builder.json",
    "package:win": "npm run build && electron-builder --win --x64 --config resources/builder.json",
    "package:mac": "npm run build && electron-builder --mac --config resources/builder.json",
    "package:linux": "npm run build && electron-builder --linux --config resources/builder.json",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "node scripts/run-tests.cjs",
    "clean": "rimraf release/app/dist release/build .erb/dll",
    "pretest": "npm run type-check"
  },
  "electronmon": {
    "patterns": [
      "!**/**",
      "release/app/dist/main/**"
    ],
    "logLevel": "quiet"
  },
